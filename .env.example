# Copy to .env and fill in. .env is gitignored.

# Engines. Two roles: a VISION engine describes the diagrams, a WRITER engine
# narrates. Each can be one of:
#   claude_code  - your Claude subscription via the `claude` CLI (no API key)
#   codex        - your OpenAI subscription via the `codex` CLI (no API key)
#   claude       - Anthropic API (needs ANTHROPIC_API_KEY below)
#   ollama       - fully local on your own server
# Rules: same value for both = one combined pass. VISION_PROVIDER=off skips vision
# and narrates from Cisco's built-in alt-text captions (fastest).
VISION_PROVIDER=claude_code
WRITER_PROVIDER=codex

# Fallback writer if WRITER_PROVIDER is unset.
LLM_PROVIDER=claude_code

# --- claude_code (subscription) ---
# CLAUDE_BIN=claude            # path to the claude CLI if not on PATH
# CLAUDE_CODE_MODEL=           # e.g. claude-opus-4-8; blank = CLI default

# --- codex / OpenAI (subscription) ---
# CODEX_BIN=codex
# CODEX_MODEL=                 # e.g. gpt-5; blank = CLI default

# --- claude (API key) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# Needed only when LLM_PROVIDER=ollama. Use a vision-capable model.
OLLAMA_MODEL=llama3.2-vision

# Where Ollama runs. Default is this machine; point at another box on your LAN
# if Ollama runs on a separate server, e.g. http://192.168.1.50:11434
OLLAMA_HOST=http://localhost:11434

# How long (seconds) to wait on the Ollama server before giving up. Bump this up
# if your server is slow to warm a cold model.
OLLAMA_TIMEOUT=600

# Kokoro voice + speaking speed (1.0 = normal).
TTS_VOICE=af_heart
TTS_SPEED=1.0

# Chrome remote-debugging endpoint that capture attaches to.
CDP_URL=http://localhost:9222

# Local player server.
HOST=127.0.0.1
PORT=8765
