# Copy to .env and fill in. .env is gitignored.

# Engines. Two roles: a VISION engine reads the diagrams, a WRITER engine writes
# the narration. Set each to one of:
#   claude_code  - Claude subscription via the `claude` CLI, no API key   (recommended for VISION)
#   codex        - OpenAI subscription via the `codex` CLI, no API key     (recommended for WRITER)
#   claude       - Anthropic API            (needs ANTHROPIC_API_KEY)
#   gemini       - Google Gemini API        (needs GEMINI_API_KEY)
#   grok         - xAI Grok API              (needs XAI_API_KEY; pick a vision model for VISION)
#   openrouter   - OpenRouter API, fronts many models (needs OPENROUTER_API_KEY)
#   ollama       - fully local on your own machine/server
#   off          - VISION only: skip vision, narrate from the page's own alt-text (fastest)
# Same value for both roles = one combined pass. The defaults below are the recommended pair.
VISION_PROVIDER=claude_code        # (recommended)
WRITER_PROVIDER=codex              # (recommended)

# Fallback writer if WRITER_PROVIDER is unset.
LLM_PROVIDER=claude_code

# Model ids per engine. Leave the CLI model blank to use whatever that CLI is
# already set to. The names below are EXAMPLES — confirm the exact id is available
# to your account/CLI before relying on it (model lineups change often).

# --- claude_code  (Claude subscription, `claude` CLI) ---
# CLAUDE_BIN=claude                # path to the claude CLI if not on PATH
# CLAUDE_CODE_MODEL=               # blank = CLI default (recommended). Examples:
#     claude-opus-4-8 (most capable) · claude-sonnet-4-6 (faster) · claude-haiku-4-5 (fastest)

# --- codex  (OpenAI / ChatGPT subscription, `codex` CLI) ---
# CODEX_BIN=codex
# CODEX_MODEL=                     # blank = CLI default (recommended). Examples:
#     gpt-5-codex · gpt-5 · gpt-5-mini · o4-mini

# --- claude  (Anthropic API key) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8       # (recommended) · others: claude-sonnet-4-6, claude-haiku-4-5-20251001

# --- gemini  (Google API key) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash      # (recommended) · others: gemini-2.5-pro, gemini-2.0-flash

# --- grok / xAI  (API key) — use a vision-capable model for the VISION role ---
XAI_API_KEY=
GROK_MODEL=grok-2-vision-1212      # others: grok-4, grok-2-1212 (text-only)

# --- openrouter  (API key) — set the model slug, "provider/model" ---
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=anthropic/claude-sonnet-4    # others: google/gemini-2.5-flash,
#     openai/gpt-5, x-ai/grok-2-vision, meta-llama/llama-3.2-90b-vision-instruct

# --- ollama  (fully local) — use a vision-capable model for the VISION role ---
OLLAMA_MODEL=llama3.2-vision       # vision: qwen2.5vl, llava, minicpm-v · text writer: qwen3
# Where Ollama runs. Default is this machine; point at another box on your LAN
# if Ollama runs on a separate server, e.g. http://192.168.1.50:11434
OLLAMA_HOST=http://localhost:11434
# How long (seconds) to wait on the Ollama server before giving up. Bump this up
# if your server is slow to warm a cold model.
OLLAMA_TIMEOUT=600

# Kokoro voice + speaking speed (1.0 = normal).
TTS_VOICE=af_heart
TTS_SPEED=1.0

# Chrome remote-debugging endpoint that capture attaches to.
CDP_URL=http://localhost:9222

# Local player server.
HOST=127.0.0.1
PORT=8765
